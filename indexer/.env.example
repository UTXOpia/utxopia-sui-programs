# UTXOpia Sui indexer configuration

# Required: deployment to index
UTXOPIA_SUI_PACKAGE_ID=0x916737cd9b1970eb5b8b400a501ac07cd7ffa25d5da433cf9391ee4e44a2da05
UTXOPIA_SUI_POOL_OBJECT_ID=0xb26294ec15a509a9f03ff1d27c39c31c421d0cfbe4ef5b6fe7d2f348bffaa8e2
# Events package == package for the current deployment (fresh redeploy, not an upgrade).
# Only override this if indexing a deployment that was upgraded in place.
UTXOPIA_SUI_EVENTS_PACKAGE_ID=0x916737cd9b1970eb5b8b400a501ac07cd7ffa25d5da433cf9391ee4e44a2da05

# Data source: jsonrpc (default, reliable) or graphql (native, fewer round-trips)
UTXOPIA_SUI_INDEXER_SOURCE=jsonrpc
UTXOPIA_SUI_RPC_URL=https://fullnode.testnet.sui.io:443
# UTXOPIA_SUI_GRAPHQL_URL=https://sui-testnet.mystenlabs.com/graphql

# Persisted sqlite path (mount a Railway volume here). Omit → in-memory (dev only).
UTXOPIA_SUI_INDEXER_DB=/data/sui-indexer.db

# Optional: BTC pool address surfaced in shield btcMeta; ingest poll interval; HTTP port
# UTXOPIA_SUI_POOL_BTC_ADDRESS=
UTXOPIA_SUI_INDEXER_POLL_MS=5000
PORT=8787
